<%- include('../partials/head') %>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <main class="container mx-auto bg-white shadow-lg rounded-lg p-8 mt-10 max-w-xl">
      <h2 class="text-3xl text-red-500 font-bold text-center mb-6">
        Hosr omr
      </h2>
      <ul class="space-y-4">
        <% reg.forEach(home => { %>
          <li class="bg-gray-100 p-4 rounded-lg shadow-md hover:shadow-lg transition duration-300">
            <h3>House Name : </h3>
            <span class=" <% %>text-lg text-gray-800"><%= home.houseName %></span>
            <h3>Price per night : </h3>
            <span class="text-lg text-gray-800"><%= home.price %></span>
            <h3>Rating : </h3>
            <span class="text-lg text-gray-800"><%= home.rating %></span>
            <h3>Image : </h3>
            <img 
            src="<%= home.urll %>" 
            alt="House Image"
            class="w-full h-48 object-cover rounded-md mb-4"
            <div>
              <a href="/host/edit-home/<%= home.id %>?editing=true" class="bg-blue-500 p-2">Edit</a>
              <form action="/host/delete-home/<%= home.id %>" method="POST">
              <button type="submit" class="bg-red-500 p-2 right-14">Delete</button>
            </form>
            </div>
        
          </li>
        <% }) %>
      </ul>
    </main>
  </body>
</html>